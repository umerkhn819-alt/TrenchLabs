# Required for admin login (/api/auth/login) in all environments you use the dashboard.
ADMIN_PASSWORD=

# Required: min 32 characters in production; use a long random string.
JWT_SECRET=

# Comma-separated browser origins allowed to call the API (CORS).
# Example: https://trenchlabs.com,https://www.trenchlabs.com
# Local dev: leave unset to default to localhost:5173,5174,3000
FRONTEND_ORIGIN=

# Supabase (optional — without these, API uses backend/db_sandbox.json)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PORT=5000

# Optional: Slack incoming webhook for new lead notifications
SLACK_WEBHOOK_URL=
