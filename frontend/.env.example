# Next.js client env vars
# Public site URL for SEO canonicals / OG (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://trenchlabs.com

# Supabase Edge Function base URL
# Local example: http://127.0.0.1:54321/functions/v1/api
# Prod example: https://<project-ref>.supabase.co/functions/v1/api
NEXT_PUBLIC_API_URL=

# Optional analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional browser Supabase client (not used by forms/admin APIs)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
