# Public site URL for SEO canonicals / OG (no trailing slash)
VITE_SITE_URL=https://trenchlabs.com

# When the frontend and API are on different origins, set the full API base path (no trailing slash).
# Example: https://your-api.fly.dev/api  — must match routes mounted at /api on the server.
# Leave unset for local dev (Vite proxies /api → backend).
# VITE_API_URL=

# Optional analytics (see src/components/Analytics.tsx)
VITE_PLAUSIBLE_DOMAIN=
VITE_GA_MEASUREMENT_ID=

# Future: read-only Supabase in the browser (RLS). Forms use the API, not these keys.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
